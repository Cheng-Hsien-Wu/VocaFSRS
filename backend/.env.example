# Environment name: development, production, or test
VOCAB_ENV=development

# Database Configuration (WAL mode, Full Sync, and Foreign Keys are enabled automatically)
# Local development uses repo-local ignored runtime data.
# For production, place the database in a secure writable path outside the source tree.
DATABASE_URL=
# SQLite file path. This wins over DATABASE_URL when set.
DATABASE_PATH=data/vocab.db

# CORS configuration: comma-separated list of allowed origins.
# Avoid permissive "*" wildcards in production. If served behind reverse proxy on the same host,
# it can be set to the proxy domain.
# Add your LAN dev-server origin here when testing from a phone, for example http://192.0.2.10:5173.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM adjudication for typed formal review.
# Put your real keys in backend/.env, never in frontend code.
# Runtime settings can also be changed from the local web settings page.
# LLM_PROVIDER supports auto, gemini, openrouter, openai_compatible.
LLM_PROVIDER=auto
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/owl-alpha
OPENROUTER_SITE_URL=http://localhost:8080
OPENROUTER_APP_NAME=VocaFSRS
GOOGLE_API_KEY=
LLM_MODEL=gemini-2.5-flash
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gemini-2.5-flash
OPENAI_COMPATIBLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
LLM_TIMEOUT_SECONDS=45

# Daily report/export timezone for NotebookLM mistake exports.
REPORT_TIMEZONE=Asia/Taipei

# Optional Discord reminder when the next FSRS review is due.
DISCORD_WEBHOOK_URL=
APP_PUBLIC_URL=http://192.0.2.10:8080
NOTIFICATION_POLL_SECONDS=60
